---
import { config } from '../data/site.config';
import ProjectImage from './ProjectImage.astro';
import BeforeAfter from './BeforeAfter.astro';

const stageLabel: Record<string, string> = { before: 'Before', after: 'After', process: 'In progress' };
const stageClass: Record<string, string> = {
  before: 'bg-ink/85 text-white',
  after: 'bg-sage-deep/90 text-white',
  process: 'bg-coral/90 text-white',
};
const filters = [
  { key: 'all', label: 'All' },
  { key: 'before', label: 'Before' },
  { key: 'after', label: 'After' },
  { key: 'process', label: 'In progress' },
];
---
<section id="work" class="relative scroll-mt-24 overflow-hidden bg-cream">
  <div class="grain absolute inset-0" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">
    <div class="grid items-center gap-10 lg:grid-cols-2">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-coral-deep">Real ductwork, real homes</p>
        <h2 class="mt-2 text-3xl text-ink sm:text-4xl">The job other companies <span class="wave-underline">couldn't get right</span></h2>
        <p class="mt-4 text-lg text-ink-soft">
          Leaky, crushed, and worn-out ducts dump your cold air into the attic. Abundant Air pulls the failed
          runs, fabricates new sheet-metal where it's needed, and installs sealed, insulated duct so every
          room actually cools. This was a tough La Quinta job. Here's the difference.
        </p>
        <a href="#quote" class="mt-6 inline-flex items-center gap-2 rounded-full bg-coral px-6 py-3 font-semibold text-white shadow-soft transition-colors hover:bg-coral-deep">
          Get this done at your place
        </a>
        <div class="mt-5 flex gap-2" data-ba-tabs>
          <button type="button" data-ba-tab="duct" class="rounded-full border px-4 py-1.5 text-sm font-semibold transition-colors border-ink bg-ink text-paper">Ductwork</button>
          <button type="button" data-ba-tab="split" class="rounded-full border px-4 py-1.5 text-sm font-semibold transition-colors border-sandline bg-paper text-ink-soft hover:border-ink/30">Mini Split</button>
        </div>
      </div>
      <div data-ba-panels>
        <div data-ba-panel="duct">
          <BeforeAfter />
        </div>
        <div data-ba-panel="split" class="hidden">
          <BeforeAfter
            before="mini-split-before.jpg"
            after="mini-split-after.jpg"
            beforeAlt="Room before ductless mini split installation by Abundant Air"
            afterAlt="Wall-mounted Mirage mini split installed by Abundant Air, La Quinta CA"
            caption="Drag to compare · room with no cooling → Mirage X Life mini split by Abundant Air"
            label="Drag to compare mini split before and after"
          />
        </div>
      </div>
    </div>

    <!-- filterable gallery -->
    <div class="mt-14" data-gallery>
      <div class="flex flex-wrap gap-2">
        {filters.map((f, i) => (
          <button
            type="button"
            data-filter={f.key}
            class:list={[
              'rounded-full border px-4 py-1.5 text-sm font-semibold transition-colors',
              i === 0 ? 'border-ink bg-ink text-paper' : 'border-sandline bg-paper text-ink-soft hover:border-ink/30',
            ]}
          >{f.label}</button>
        ))}
      </div>

      <ul class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4">
        {config.gallery.map((g, i) => (
          <li data-stage={g.stage} style={`--i:${i}`} class="group overflow-hidden rounded-2xl border border-sandline bg-paper shadow-soft">
            <div class="relative">
              <ProjectImage src={g.src} alt={g.alt} widths={[300, 600]} sizes="(max-width:640px) 50vw, 25vw" class="aspect-square w-full object-cover transition-transform duration-500 group-hover:scale-105" />
              <span class:list={['absolute left-2 top-2 rounded-full px-2.5 py-0.5 text-[0.7rem] font-semibold shadow', stageClass[g.stage]]}>{stageLabel[g.stage]}</span>
            </div>
            <p class="px-3 py-2.5 text-xs leading-snug text-ink-soft">{g.caption}</p>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<script>
  // Before/after tabs
  document.querySelectorAll<HTMLElement>('[data-ba-tabs]').forEach((tabs) => {
    const panels = tabs.closest('.grid')?.querySelector('[data-ba-panels]');
    if (!panels) return;
    tabs.querySelectorAll<HTMLButtonElement>('[data-ba-tab]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.baTab!;
        tabs.querySelectorAll<HTMLButtonElement>('[data-ba-tab]').forEach((b) => {
          const on = b === btn;
          b.classList.toggle('bg-ink', on);
          b.classList.toggle('text-paper', on);
          b.classList.toggle('border-ink', on);
          b.classList.toggle('bg-paper', !on);
          b.classList.toggle('text-ink-soft', !on);
          b.classList.toggle('border-sandline', !on);
        });
        panels.querySelectorAll<HTMLElement>('[data-ba-panel]').forEach((p) => {
          p.classList.toggle('hidden', p.dataset.baPanel !== key);
          // reset slider position when switching
          const ba = p.querySelector<HTMLElement>('.ba');
          const range = p.querySelector<HTMLInputElement>('.ba-range');
          if (ba && range) { range.value = '50'; ba.style.setProperty('--pos', '50%'); }
        });
      });
    });
  });

  document.querySelectorAll<HTMLElement>('[data-gallery]').forEach((root) => {
    const buttons = root.querySelectorAll<HTMLButtonElement>('[data-filter]');
    const items = root.querySelectorAll<HTMLElement>('[data-stage]');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.filter;
        buttons.forEach((b) => {
          const on = b === btn;
          b.classList.toggle('bg-ink', on);
          b.classList.toggle('text-paper', on);
          b.classList.toggle('border-ink', on);
          b.classList.toggle('bg-paper', !on);
          b.classList.toggle('text-ink-soft', !on);
          b.classList.toggle('border-sandline', !on);
        });
        items.forEach((it) => {
          const show = key === 'all' || it.dataset.stage === key;
          it.style.display = show ? '' : 'none';
        });
      });
    });
  });
</script>
