---
import { config } from '../data/site.config';
import Icon from './Icon.astro';

const services = config.services;
const [lead, ...rest] = services;
---
<section id="services" class="mx-auto max-w-6xl scroll-mt-24 px-4 py-16 sm:px-6 lg:py-20">
  <div class="max-w-2xl">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sage-deep">What we do</p>
    <h2 class="mt-2 text-3xl text-ink sm:text-4xl">HVAC that holds up to a <span class="wave-underline">desert summer</span></h2>
    <p class="mt-4 text-lg text-ink-soft">One trusted tech for repair, installs, heating, and the ductwork that makes any system actually perform.</p>
  </div>

  <div class="mt-10 grid gap-5 lg:grid-cols-3">
    <!-- Lead/featured service spans wide -->
    <a href={`/services/${lead.id}`} class="group relative overflow-hidden rounded-3xl border border-sandline bg-gradient-to-br from-ink to-[#22463d] p-7 text-paper shadow-soft transition-shadow hover:shadow-lift lg:col-span-2 lg:row-span-2 lg:p-9">
      <span class="grid h-12 w-12 place-items-center rounded-2xl bg-coral text-white"><Icon name={lead.icon} class="h-6 w-6" /></span>
      <span class="mt-5 inline-block rounded-full bg-paper/15 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-paper">Our specialty</span>
      <h3 class="mt-3 text-2xl text-paper sm:text-3xl">{lead.name}</h3>
      <p class="mt-3 max-w-lg text-paper/80">{lead.shortDesc}</p>
      <ul class="mt-5 grid gap-2 sm:grid-cols-2">
        {lead.bullets.map((b) => (
          <li class="flex items-start gap-2 text-sm text-paper/85"><Icon name="check" class="mt-0.5 h-4 w-4 shrink-0 text-sage" />{b}</li>
        ))}
      </ul>
      <span class="mt-6 inline-flex items-center gap-1.5 font-semibold text-coral transition-transform group-hover:translate-x-1">See how it works →</span>
    </a>

    {rest.map((s) => (
      <a href={`/services/${s.id}`} class="group flex flex-col rounded-3xl border border-sandline bg-cream p-6 shadow-soft transition-all hover:-translate-y-0.5 hover:shadow-lift">
        <span class="grid h-11 w-11 place-items-center rounded-2xl bg-coral-tint text-coral-deep"><Icon name={s.icon} class="h-5 w-5" /></span>
        <h3 class="mt-4 text-xl text-ink">{s.name}</h3>
        <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-soft">{s.shortDesc}</p>
        <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-sage-deep transition-transform group-hover:translate-x-1">Learn more →</span>
      </a>
    ))}
  </div>
</section>
