---
import { config } from '../data/site.config';
import ProjectImage from './ProjectImage.astro';
import Icon from './Icon.astro';

interface Props {
  before?: string;
  after?: string;
  beforeAlt?: string;
  afterAlt?: string;
  caption?: string;
  label?: string;
}

const ba = config.featuredBeforeAfter;
const {
  before = ba.before,
  after = ba.after,
  beforeAlt = ba.beforeAlt,
  afterAlt = ba.afterAlt,
  caption = 'Drag to compare · failing fiberglass duct → new sealed flex by Abundant Air',
  label = 'Drag to compare before and after',
} = Astro.props;
---
<div class="relative">
  <div
    class="ba group relative aspect-[4/3] w-full select-none overflow-hidden rounded-3xl border border-sandline shadow-lift"
    style="--pos:50%"
  >
    <div class="absolute inset-0">
      <ProjectImage src={after} alt={afterAlt} widths={[600, 1000, 1400]} sizes="(max-width:1024px) 100vw, 640px" class="h-full w-full object-cover" />
      <span class="absolute right-3 top-3 rounded-full bg-sage-deep/90 px-3 py-1 text-xs font-semibold text-white shadow">After</span>
    </div>
    <div class="ba-before absolute inset-0" style="clip-path: inset(0 calc(100% - var(--pos)) 0 0)">
      <ProjectImage src={before} alt={beforeAlt} widths={[600, 1000, 1400]} sizes="(max-width:1024px) 100vw, 640px" class="h-full w-full object-cover" />
      <span class="absolute left-3 top-3 rounded-full bg-ink/85 px-3 py-1 text-xs font-semibold text-white shadow">Before</span>
    </div>
    <div class="ba-line pointer-events-none absolute inset-y-0" style="left:var(--pos)">
      <div class="absolute inset-y-0 -ml-px w-0.5 bg-white/90"></div>
      <div class="absolute top-1/2 -ml-5 -mt-5 grid h-10 w-10 -translate-y-0 place-items-center rounded-full border-2 border-white bg-coral text-white shadow-lift">
        <Icon name="spark" class="h-5 w-5" />
      </div>
    </div>
    <input
      type="range" min="0" max="100" value="50"
      class="ba-range absolute inset-0 h-full w-full cursor-ew-resize opacity-0"
      aria-label={label}
    />
  </div>
  <p class="mt-3 text-center text-sm text-ink-soft">{caption}</p>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.ba').forEach((box) => {
    const range = box.querySelector<HTMLInputElement>('.ba-range');
    if (!range) return;
    const set = (v: string) => box.style.setProperty('--pos', v + '%');
    range.addEventListener('input', () => set(range.value));
  });
</script>
