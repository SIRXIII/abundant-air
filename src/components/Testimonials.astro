---
import { config } from '../data/site.config';
import Icon from './Icon.astro';
const t = config.testimonials;
---
<section id="reviews" class="mx-auto max-w-6xl scroll-mt-24 px-4 py-16 sm:px-6 lg:py-20">
  <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sage-deep">Neighbors in the valley</p>
      <h2 class="mt-2 text-3xl text-ink sm:text-4xl">A perfect <span class="wave-underline">5.0</span> on Google</h2>
    </div>
    <a href={config.rating.url} target="_blank" rel="noopener"
      class="inline-flex items-center gap-2 rounded-full border border-sandline bg-cream px-4 py-2 text-sm font-semibold text-ink shadow-soft hover:border-ink/30">
      <span class="flex text-coral">{Array.from({ length: 5 }).map(() => (<Icon name="star" class="h-4 w-4" />))}</span>
      Read all {config.rating.count} on Google
    </a>
  </div>

  <div class="mt-10 columns-1 gap-5 sm:columns-2 lg:columns-3 [&>*]:mb-5">
    {t.map((r) => (
      <figure class="break-inside-avoid rounded-3xl border border-sandline bg-cream p-6 shadow-soft">
        <div class="flex items-center gap-1 text-coral">{Array.from({ length: r.rating }).map(() => (<Icon name="star" class="h-4 w-4" />))}</div>
        <blockquote class="mt-3 text-ink-soft">“{r.text}”</blockquote>
        <figcaption class="mt-4 flex items-center gap-3">
          <span class="grid h-9 w-9 place-items-center rounded-full bg-sage-tint font-semibold text-sage-deep">{r.name.charAt(0)}</span>
          <span>
            <span class="block font-semibold leading-tight text-ink">{r.name}</span>
            <span class="block text-xs text-ink-soft">Verified Google review</span>
          </span>
        </figcaption>
      </figure>
    ))}
  </div>
</section>
