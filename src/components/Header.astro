---
import { config } from '../data/site.config';
import Logo from './Logo.astro';
import Icon from './Icon.astro';

const nav = [
  { href: '/#services', label: 'Services' },
  { href: '/#work', label: 'Our Work' },
  { href: '/#reviews', label: 'Reviews' },
  { href: '/#areas', label: 'Areas' },
];
---
<header class="sticky top-0 z-50 border-b border-sandline bg-paper/95 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-2.5 sm:px-6">
    <a href="/" class="flex items-center gap-3" aria-label={`${config.businessName} home`}>
      <video
        id="logo-vid"
        autoplay
        loop
        muted
        playsinline
        src="/logo-video.mp4"
        class="h-24 w-auto sm:h-28"
        aria-label={config.brand.logoAlt}
      >
        <Logo class="h-24 w-auto sm:h-28" width={320} />
      </video>
    </a>

    <nav class="hidden items-center gap-7 text-[0.95rem] font-medium text-ink-soft md:flex">
      {nav.map((n) => (
        <a href={n.href} class="transition-colors hover:text-ink">{n.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="/#quote"
        class="hidden rounded-full border border-sage px-4 py-2 text-sm font-semibold text-sage-deep transition-colors hover:bg-sage-tint sm:inline-flex"
      >
        Get a Quote
      </a>
      <a
        href={`tel:${config.phone}`}
        class="inline-flex items-center gap-2 rounded-full bg-coral px-3.5 py-2 text-sm font-semibold text-white shadow-soft transition-colors hover:bg-coral-deep sm:px-5"
        data-call
      >
        <Icon name="phone" class="h-4 w-4" />
        <span class="hidden sm:inline">{config.phoneDisplay}</span>
        <span class="sm:hidden">Call now</span>
      </a>
    </div>
  </div>
</header>
<script>
  const v = document.getElementById('logo-vid') as HTMLVideoElement | null;
  if (v) v.addEventListener('canplay', () => v.play().catch(() => {}), { once: true });
</script>
