---
import { config } from '../data/site.config';
import Icon from './Icon.astro';

const items = [
  { icon: 'star', label: `${config.rating.value.toFixed(1)}★ on Google`, sub: `${config.rating.count} five-star reviews` },
  { icon: 'clock', label: 'Fast response', sub: 'Same-day & after-hours' },
  { icon: 'shield', label: 'Licensed & insured', sub: config.trust.licenseNumber ? `Lic. #${config.trust.licenseNumber}` : 'Lic. # on request' },
  { icon: 'leaf', label: 'Fair, honest pricing', sub: 'No double-the-quote games' },
];
---
<section class="border-y border-sandline bg-cream">
  <div class="mx-auto grid max-w-6xl grid-cols-2 gap-x-4 gap-y-6 px-4 py-7 sm:px-6 lg:grid-cols-4">
    {items.map((it) => (
      <div class="flex items-center gap-3">
        <span class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-sage-tint text-sage-deep">
          <Icon name={it.icon} class="h-5 w-5" />
        </span>
        <div>
          <p class="font-semibold leading-tight text-ink">{it.label}</p>
          <p class="text-sm text-ink-soft">{it.sub}</p>
        </div>
      </div>
    ))}
  </div>
</section>
