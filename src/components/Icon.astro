---
// Inline, currentColor SVG icons. No icon-font dependency.
interface Props { name: string; class?: string; }
const { name, class: className = 'w-6 h-6' } = Astro.props;
const p = { fill: 'none', stroke: 'currentColor', 'stroke-width': '1.7', 'stroke-linecap': 'round', 'stroke-linejoin': 'round' } as const;
---
<svg viewBox="0 0 24 24" class={className} aria-hidden="true" {...p}>
  {name === 'duct' && (<><path d="M3 8h13l5 4-5 4H3z"/><path d="M3 8v8"/><path d="M8 8v8M13 8v8"/></>)}
  {name === 'wrench' && (<path d="M14.7 6.3a4 4 0 0 1-5.4 5.2L4 17l3 3 5.5-5.3a4 4 0 0 0 5.2-5.4l-2.5 2.5-2.3-.6-.6-2.3z"/>)}
  {name === 'unit' && (<><rect x="3" y="5" width="18" height="11" rx="1.5"/><path d="M6 9h12M6 12h12"/><path d="M7 19l-1 1M12 19v1M17 19l1 1"/></>)}
  {name === 'flame' && (<path d="M12 3c1 3.5 4 4.8 4 8a4 4 0 0 1-8 0c0-1.4.6-2.4 1.3-3.2C9.9 9 10 7.5 9.5 6c1.5.4 2 1.7 2.5 2 .2-1.6 0-3.4 0-5z"/>)}
  {name === 'gauge' && (<><path d="M4 14a8 8 0 0 1 16 0"/><path d="M12 14l4-3"/><path d="M4 14h2M18 14h2M12 6v0"/></>)}
  {name === 'phone' && (<path d="M5 4h3l2 5-2 1a11 11 0 0 0 5 5l1-2 5 2v3a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/>)}
  {name === 'sms' && (<path d="M4 5h16v11H8l-4 3z"/>)}
  {name === 'star' && (<path d="M12 3.5l2.6 5.3 5.9.9-4.2 4.1 1 5.8L12 17l-5.3 2.8 1-5.8L3.5 9.7l5.9-.9z" fill="currentColor" stroke="none"/>)}
  {name === 'check' && (<path d="M4 12.5l5 5 11-11"/>)}
  {name === 'shield' && (<path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6z"/>)}
  {name === 'clock' && (<><circle cx="12" cy="12" r="8.5"/><path d="M12 7.5V12l3 2"/></>)}
  {name === 'map' && (<><path d="M12 21s7-6.2 7-11a7 7 0 0 0-14 0c0 4.8 7 11 7 11z"/><circle cx="12" cy="10" r="2.4"/></>)}
  {name === 'globe' && (<><circle cx="12" cy="12" r="8.5"/><path d="M3.5 12h17M12 3.5c2.5 2.5 2.5 14 0 17M12 3.5c-2.5 2.5-2.5 14 0 17"/></>)}
  {name === 'leaf' && (<path d="M20 4C9 4 5 9 5 16c0 1 .2 2 .5 3C8 13 12 11 18 10c-5 2-8 5-11 11 8 1 13-3 13-12V4z"/>)}
  {name === 'spark' && (<path d="M12 3v4M12 17v4M3 12h4M17 12h4M6 6l2.5 2.5M15.5 15.5L18 18M18 6l-2.5 2.5M8.5 15.5L6 18"/>)}
  {name === 'air' && (<><path d="M4 10c1-2 3-3 5-2s2 4 0 5-4 0-3-3"/><path d="M3 16c1-1.5 3-2 4-1s1.5 3 0 3.5-3 0-2.5-2.5"/><path d="M2 12h20M5 8h14"/></>)}
  {name === 'split' && (<><rect x="4" y="4" width="16" height="8" rx="1.5"/><path d="M7 8h10"/><path d="M12 12v4M9 20c0-2.2 1.3-4 3-4s3 1.8 3 4"/></>)}
</svg>
