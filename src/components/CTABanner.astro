---
import { config } from '../data/site.config';
import Icon from './Icon.astro';
import AirWave from './AirWave.astro';
interface Props { heading?: string; sub?: string; }
const {
  heading = "Let's get your air right.",
  sub = `Honest HVAC and expert ductwork across ${config.primaryCity} and the ${config.region}.`,
} = Astro.props;
---
<section class="relative overflow-hidden bg-gradient-to-br from-coral via-[#e08a5f] to-sun text-white">
  <AirWave class="text-paper" flip={true} />
  <div class="mx-auto flex max-w-5xl flex-col items-center gap-5 px-4 py-14 text-center sm:px-6 lg:py-16">
    <h2 class="text-3xl text-white sm:text-4xl lg:text-[2.7rem]">{heading}</h2>
    <p class="max-w-2xl text-lg text-white/90">{sub}</p>
    <div class="flex flex-col gap-3 sm:flex-row">
      <a href={`tel:${config.phone}`} data-call class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-7 py-3.5 text-base font-semibold text-coral-deep shadow-lift transition-transform hover:-translate-y-0.5">
        <Icon name="phone" class="h-5 w-5" /> Call {config.phoneDisplay}
      </a>
      <a href={`sms:${config.phoneSms}`} class="inline-flex items-center justify-center gap-2 rounded-full border-2 border-white/80 px-7 py-3.5 text-base font-semibold text-white transition-colors hover:bg-white/15">
        <Icon name="sms" class="h-5 w-5" /> Text us
      </a>
    </div>
    <p class="text-sm text-white/85">5.0★ on Google · Licensed &amp; insured{config.trust.bilingualEs ? ' · Se habla español' : ''}</p>
  </div>
</section>
