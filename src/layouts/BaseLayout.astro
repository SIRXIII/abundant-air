---
import BaseHead from './BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCallBar from '../components/FloatingCallBar.astro';

interface Props {
  title: string;
  description?: string;
  path?: string;
}
const { title, description, path } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} path={path} />
  </head>
  <body class="min-h-screen antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded-lg focus:bg-ink focus:px-4 focus:py-2 focus:text-paper">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <FloatingCallBar />
  </body>
</html>
